# =============================================================================
# Copy to `.env` and fill in. Do NOT commit `.env`.
# Values below are the defaults — uncomment and change anything you need.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production

# Port to bind. On Hostinger shared Node hosting, leave this UNSET — Passenger
# / LiteSpeed assigns PORT for you automatically. On a VPS behind Nginx, use
# 3000 (or any free port). Default is 3000.
# PORT=3000

# Host to bind the HTTP server.
#   Hostinger shared Node hosting (Passenger):   BIND_HOST=   (empty)
#   VPS behind Nginx on the same box:            BIND_HOST=127.0.0.1
#   VPS exposed directly (not recommended):      BIND_HOST=0.0.0.0
BIND_HOST=127.0.0.1

# How many reverse-proxy hops to trust for X-Forwarded-For / X-Forwarded-Proto.
#   Hostinger shared hosting:  1
#   Nginx on same VPS:         1
#   Cloudflare -> Nginx:       2
#   No reverse proxy at all:   0
TRUST_PROXY=1

# Force `Secure` on the admin cookie even if NODE_ENV!=production.
# SECURE_COOKIES=true

# ---- Gmail (confirmation email) --------------------------------------------
# Create a 16-char App Password at https://myaccount.google.com/apppasswords
# (2-Step Verification must be enabled first)
GMAIL_USER=rmithanoitheatrclub@gmail.com
GMAIL_APP_PASSWORD=

MAIL_FROM_NAME=Theat.R - RMIT Hanoi Musical Theatre Club
# Set to "true" to skip sending email (useful for local dev)
DISABLE_EMAIL=false

# ---- Admin panel (/admin) ---------------------------------------------------
# Leave ADMIN_PASSWORD empty to DISABLE the admin panel entirely.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ---- Storage ----------------------------------------------------------------
# In production the DB defaults to `<app-parent>/theatre-data/theatre.db`,
# i.e. ONE DIRECTORY ABOVE the app folder, so re-deploys (FTP overwrite,
# git pull, or even `rm -rf public_html && git clone`) never touch the data.
#
#   Hostinger shared:  ~/domains/<site>/public_html  → ~/domains/<site>/theatre-data/theatre.db
#   VPS (Path B):      /var/www/theatre              → /var/www/theatre-data/theatre.db
#
# On first boot after this change the server auto-migrates any legacy
# `theatre.db` (+ WAL sidecars) it finds in the app folder.
#
# If you'd rather pin the DB to an explicit absolute path (e.g. a mounted
# volume), set DB_PATH below. BANK_SCREENSHOT is a deployable asset shipped
# with the code, so it stays inside the app folder unless overridden.
# DB_PATH=/var/lib/theatre/theatre.db
# BANK_SCREENSHOT=/var/lib/theatre/payment.jpeg
