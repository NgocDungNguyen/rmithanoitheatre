# =============================================================================
# example.env — copy values into hPanel's "Environment Variables" panel
# (hPanel → rmithanoitheatre.shop → Advanced → Node.js → your app)
#
# OR copy this file to `.env` in public_html/ and chmod 600 .env
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=production

# Leave BIND_HOST EMPTY on Hostinger shared Node hosting — Passenger / LiteSpeed
# picks the socket/port for us. Setting 127.0.0.1 here will break booting.
BIND_HOST=

# Do NOT set PORT — Hostinger fills it in.

# 1 = trust one reverse-proxy hop (Hostinger's front-end Apache/LiteSpeed).
TRUST_PROXY=1

# Force the admin cookie `Secure` flag (always required in prod / over HTTPS).
SECURE_COOKIES=true

# ---- Gmail (sends bilingual confirmation emails) ---------------------------
# 1. Enable 2-Step Verification on rmithanoitheatrclub@gmail.com
#    → https://myaccount.google.com/security
# 2. Create an App Password for "Mail"
#    → https://myaccount.google.com/apppasswords
# 3. Paste the 16-char password below (NOT your Google account password).
GMAIL_USER=rmithanoitheatrclub@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

MAIL_FROM_NAME=Theat.R - RMIT Hanoi Musical Theatre Club

# Flip to "true" if you want to test bookings without sending real emails.
DISABLE_EMAIL=false

# ---- Admin panel (/admin) ---------------------------------------------------
# Leave ADMIN_PASSWORD empty to DISABLE /admin entirely.
# Generate a strong one with:  openssl rand -base64 24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD

# ---- Storage (optional) ----------------------------------------------------
# By default theatre.db lives next to server.js (inside public_html/).
# Override these if you mount the DB on a separate persistent volume.
# DB_PATH=/home/u960951907/theatre-data/theatre.db
# BANK_SCREENSHOT=/home/u960951907/theatre-data/payment.jpeg
